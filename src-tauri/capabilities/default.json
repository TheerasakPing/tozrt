{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for NexTorrent",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "dialog:default",
    "fs:default",
    "shell:default",
    "notification:default",
    "core:window:allow-destroy",
    "core:window:allow-close"
  ]
}
